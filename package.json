{
  "name": "@flit/sveltekit-adapter-pdf-gen-cdk",
  "version": "1.2.1",
  "description": "This SvelteKit adapter generates a CDK construct for a PDF generation service",
  "keywords": [
    "aws",
    "awscdk",
    "sveltekit",
    "pdf"
  ],
  "homepage": "https://github.com/vierroth/sveltekit-adapter-pdf-gen-cdk",
  "bugs": "https://github.com/vierroth/sveltekit-adapter-pdf-gen-cdk/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/vierroth/sveltekit-adapter-pdf-gen-cdk.git"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Vierroth GmbH",
    "url": "https://github.com/vierroth"
  },
  "contributors": [
    {
      "name": "Luis Vierroth",
      "url": "https://github.com/p-mercury"
    }
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "./dist",
    "./puppeteer-layer.zip",
    "./LICENSE.txt",
    "./README.md"
  ],
  "scripts": {
    "build": "npm run prepack",
    "prepack": "rm -rf ./dist && tsc -b"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-packagejson",
      "prettier-plugin-svelte"
    ],
    "tabWidth": 2,
    "overrides": [
      {
        "files": "*.sublime-project",
        "options": {
          "parser": "json"
        }
      }
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.896.0",
    "@aws-sdk/credential-providers": "^3.896.0",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@sparticuz/chromium": "138.0.2",
    "@sveltejs/adapter-node": "^5.3.2",
    "@sveltejs/kit": "^2.43.5",
    "@types/aws-lambda": "^8.10.152",
    "@types/node": "^24.5.2",
    "aws-cdk-lib": "^2.218.0",
    "puppeteer-core": "24.15.0",
    "rollup": "^4.52.3"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "prettier-plugin-packagejson": "^2.5.19",
    "prettier-plugin-svelte": "^3.4.0",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "stability": "stable"
}
